# Application
APP_ENV=development
SECRET_KEY=CHANGEME_GENERATE_A_RANDOM_SECRET
DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=osint
POSTGRES_USER=osint
POSTGRES_PASSWORD=CHANGEME_GENERATE_A_RANDOM_PASSWORD

# Redis
REDIS_URL=redis://redis:6379/0

# Neo4j
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=CHANGEME_GENERATE_A_RANDOM_PASSWORD

# MinIO
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=CHANGEME_GENERATE_A_RANDOM_PASSWORD
MINIO_BUCKET=osint-data
MINIO_USE_SSL=false

# JWT
JWT_SECRET_KEY=CHANGEME_GENERATE_A_RANDOM_SECRET
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# Crypto Payments (placeholder)
CRYPTO_PAYMENT_PROVIDER_URL=
CRYPTO_PAYMENT_API_KEY=
CRYPTO_WEBHOOK_SECRET=

# OSINT Settings
OSINT_SCAN_TIMEOUT_SECONDS=120
OSINT_MAX_CONCURRENT_SCANS=5
OSINT_DEFAULT_SCAN_DEPTH=2

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# RSSHub (self-hosted X/Twitter scraping)
RSSHUB_SELF_HOSTED_URL=http://rsshub:1200
