# =============================================================================
# Application
# =============================================================================
APP_ENV=development
SECRET_KEY=CHANGEME_GENERATE_A_RANDOM_SECRET
DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1

# =============================================================================
# Database — PostgreSQL
# =============================================================================
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=osint
POSTGRES_USER=osint
POSTGRES_PASSWORD=CHANGEME_GENERATE_A_RANDOM_PASSWORD
DATABASE_URL=postgresql+asyncpg://osint:CHANGEME_GENERATE_A_RANDOM_PASSWORD@postgres:5432/osint

# DB connection pool (per worker). (pool_size + max_overflow) * workers < max_connections
DB_POOL_SIZE=5
DB_POOL_MAX_OVERFLOW=10

# =============================================================================
# Cache & Broker — Redis
# =============================================================================
REDIS_URL=redis://redis:6379/0

# =============================================================================
# Graph Database — Neo4j
# =============================================================================
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=CHANGEME_GENERATE_A_RANDOM_PASSWORD

# =============================================================================
# Object Storage — MinIO (S3-compatible)
# =============================================================================
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=CHANGEME_GENERATE_A_RANDOM_PASSWORD
MINIO_BUCKET=osint-data
MINIO_USE_SSL=false

# =============================================================================
# Authentication — JWT
# =============================================================================
JWT_SECRET_KEY=CHANGEME_GENERATE_A_RANDOM_SECRET
JWT_REFRESH_SECRET_KEY=CHANGEME_GENERATE_ANOTHER_RANDOM_SECRET
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# PII field-level encryption key (32+ chars)
PII_ENCRYPTION_KEY=CHANGEME_GENERATE_A_32_CHAR_OR_LONGER_KEY

# =============================================================================
# Workers — Celery / Flower
# =============================================================================
FLOWER_USER=admin
FLOWER_PASSWORD=CHANGEME_GENERATE_A_RANDOM_PASSWORD

# =============================================================================
# Network / Proxy
# =============================================================================
# PROXY_MODE: direct | tor | socks5
PROXY_MODE=direct
# SOCKS5_PROXY=socks5://127.0.0.1:9050

# =============================================================================
# CORS
# =============================================================================
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# =============================================================================
# OSINT Scanner Settings
# =============================================================================
OSINT_SCAN_TIMEOUT_SECONDS=120
OSINT_MAX_CONCURRENT_SCANS=5
OSINT_DEFAULT_SCAN_DEPTH=2
OSINT_MOCK_DATA=false
SCANNER_RATE_LIMIT_COUNTS_AS_FAILURE=false

# =============================================================================
# Rate Limiting
# =============================================================================
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# =============================================================================
# Observability
# =============================================================================
# Prometheus metrics endpoint protection
METRICS_API_KEY=CHANGEME_GENERATE_A_RANDOM_SECRET

# OpenTelemetry (optional — leave blank to disable)
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=osint-platform

# =============================================================================
# External OSINT API Keys
# (all optional — leave blank to disable the corresponding scanner)
# =============================================================================

# Shodan — shodan.io — network/port scanning enrichment
SHODAN_API_KEY=

# Have I Been Pwned — haveibeenpwned.com — breach lookups
HIBP_API_KEY=

# VirusTotal — virustotal.com — malware/URL scanning
VIRUSTOTAL_API_KEY=

# Censys — censys.io — certificate & host discovery
CENSYS_API_ID=
CENSYS_API_SECRET=

# Hunter.io — hunter.io — email discovery
HUNTER_API_KEY=

# Full Contact — fullcontact.com — identity enrichment
FULLCONTACT_API_KEY=

# Clearbit — clearbit.com — company/person enrichment
CLEARBIT_API_KEY=

# urlscan.io — unlocks higher rate limits (optional)
URLSCAN_API_KEY=

# ViewDNS — viewdns.info — required for JSON API
VIEWDNS_API_KEY=

# ipinfo.io — 50k/month free with key
IPINFO_API_KEY=

# AbuseIPDB — abuseipdb.com — IOC enrichment
ABUSEIPDB_API_KEY=

# AlienVault OTX — otx.alienvault.com — threat intelligence
OTX_API_KEY=

# GreyNoise — greynoise.io — community API key
GREYNOISE_API_KEY=

# Spyonweb — spyonweb.com — shared analytics tracking
SPYONWEB_API_KEY=

# SerpAPI — serpapi.com — Google Dorking
SERPAPI_API_KEY=

# Etherscan — etherscan.io — Ethereum address tracing
ETHERSCAN_API_KEY=

# OpenCorporates — opencorporates.com — free academic tier
OPENCORPORATES_API_KEY=

# Companies House (UK) — developer.company-information.service.gov.uk — free
COMPANIES_HOUSE_API_KEY=

# BeVigil — bevigil.com — mobile app intelligence (free tier)
BEVIGIL_API_KEY=

# MarineTraffic — marinetraffic.com — vessel tracking
MARINETRAFFIC_API_KEY=

# =============================================================================
# AI / LLM
# =============================================================================
# Provider: openai | anthropic | ollama
LLM_PROVIDER=openai

OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Ollama (local LLM — optional)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# LangSmith tracing (optional)
LANGCHAIN_API_KEY=
LANGSMITH_API_KEY=

# Tavily — tavily.com — AI search
TAVILY_API_KEY=

# Qdrant (vector store — optional)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# =============================================================================
# Payments — NowPayments (crypto)
# =============================================================================
NOWPAYMENTS_API_KEY=
CRYPTO_PAYMENT_PROVIDER_URL=
CRYPTO_PAYMENT_API_KEY=
CRYPTO_WEBHOOK_SECRET=

# =============================================================================
# Security / Integrations (optional)
# =============================================================================
# SIEM integration
SIEM_ENDPOINT=
SIEM_API_KEY=

# MISP threat intelligence platform
MISP_URL=
MISP_API_KEY=

# TheHive case management
THEHIVE_URL=
THEHIVE_API_KEY=

# =============================================================================
# Self-hosted services
# =============================================================================
# RSSHub — self-hosted X/Twitter scraping
RSSHUB_SELF_HOSTED_URL=http://rsshub:1200

# Elasticsearch (optional — full-text search)
ELASTICSEARCH_URL=http://elasticsearch:9200
